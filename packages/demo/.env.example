# ============================================================================
# demo — Environment Variables
# ============================================================================
#
# The demo is a standalone Next.js app. It does NOT share any env vars with
# pds-core or auth-service. It only needs to know the public URLs of the PDS
# and auth service.
#
# How env vars are loaded depends on context:
#
#   Railway/Vercel:   Set these in the platform dashboard.
#   docker-compose:   Loaded from packages/demo/.env via env_file.
#   pnpm dev:demo:    Next.js loads packages/demo/.env automatically.

# Public URL of this demo app (used for OAuth client_id and redirect_uri).
# Must be http://127.0.0.1:<port> for local loopback, or an HTTPS URL for
# production (ATProto OAuth requires HTTPS for discoverable client IDs).
PUBLIC_URL=http://127.0.0.1:3002

# PDS URL (the ePDS instance to authenticate against)
PDS_URL=https://pds.example

# Auth endpoint (the ePDS auth service's OAuth authorize URL)
AUTH_ENDPOINT=https://auth.pds.example/oauth/authorize

# For local dev without Caddy (direct to services):
# PDS_URL=http://localhost:3000
# AUTH_ENDPOINT=http://localhost:3001/oauth/authorize

# PLC directory for DID-to-handle resolution
# PLC_DIRECTORY_URL=https://plc.directory

# Request that the PDS skip consent on initial sign-up.
# Only effective when the PDS has PDS_SIGNUP_ALLOW_CONSENT_SKIP=true
# and this client is listed in PDS_OAUTH_TRUSTED_CLIENTS.
# EPDS_SKIP_CONSENT_ON_SIGNUP=true

# Override the OAuth client_name shown on the PDS consent screen.
# Defaults to "ePDS Demo". Useful when running multiple demo instances
# (e.g. trusted + untrusted) side-by-side and the consent screen needs
# to distinguish them.
# EPDS_CLIENT_NAME=ePDS Demo

# Session signing secret (generate with: openssl rand -base64 32)
# SESSION_SECRET=change-me-in-production

# ES256 (P-256) private JWK in compact JSON form, used for OAuth
# confidential-client authentication (private_key_jwt). When set, this
# client advertises itself as a confidential client in its metadata and
# signs a client_assertion JWT on every token exchange. That's required
# to make the upstream @atproto/oauth-provider honour previously-recorded
# consent grants on return logins (see HYPER-270 / docs/design/consent-flow-fix.md).
#
# When unset, the client falls back to public-client mode, which works
# for local dev but means users see the consent screen on every login.
#
# Generate with: pnpm jwk:generate — do NOT copy the same value across
# multiple demo services in a single Railway environment; each service
# should have its OWN keypair so they can't impersonate each other.
# EPDS_CLIENT_PRIVATE_JWK={"kty":"EC","crv":"P-256","d":"...","x":"...","y":"...","kid":"..."}
