{
    email admin@{$PDS_HOSTNAME:pds.example}
    on_demand_tls {
        ask http://{$PDS_UPSTREAM:core:3000}/tls-check
    }
}
# Demo app (dedicated vhost — not part of the on-demand TLS block so it
# bypasses /tls-check). Only active when DEMO_HOSTNAME is set; in its
# absence Caddy just skips this site. Used for local e2e runs where the
# demo container needs a real hostname under the shared parent domain
# so HYPER-268 @session-reuse scenarios can exercise cross-client
# device-session sharing.
{$DEMO_HOSTNAME} {
    reverse_proxy {$DEMO_UPSTREAM:demo:3002} {
        header_up Connection {http.request.header.Connection}
        header_up Upgrade {http.request.header.Upgrade}
    }
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
    }
}

# Second demo vhost for e2e scenarios that need an untrusted OAuth client
# (HYPER-268 session-reuse, trusted-vs-untrusted branding tests). Only
# active when DEMO_UNTRUSTED_HOSTNAME is set. Same container image as the
# trusted demo, different PUBLIC_URL.
{$DEMO_UNTRUSTED_HOSTNAME} {
    reverse_proxy {$DEMO_UNTRUSTED_UPSTREAM:demo-untrusted:3002} {
        header_up Connection {http.request.header.Connection}
        header_up Upgrade {http.request.header.Upgrade}
    }
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
    }
}

# PDS API + handle subdomains (on-demand TLS for handle resolution)
:443 {
    tls {
        on_demand
    }

    # Auth service
    @auth host auth.{$PDS_HOSTNAME:pds.example}
    handle @auth {
        reverse_proxy {$AUTH_UPSTREAM:auth:3001}
        header {
            X-Frame-Options "DENY"
            X-Content-Type-Options "nosniff"
            Referrer-Policy "no-referrer"
            Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        }
    }
    # Everything else goes to PDS (main domain + handle subdomains)
    handle {
        reverse_proxy {$PDS_UPSTREAM:core:3000} {
            header_up Connection {http.request.header.Connection}
            header_up Upgrade {http.request.header.Upgrade}
        }
        header {
            Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
            X-Content-Type-Options "nosniff"
        }
    }
}
