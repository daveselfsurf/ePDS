# E2E test configuration — copy to e2e/.env and fill in values
# e2e/.env is gitignored and never committed

# ── Required ──────────────────────────────────────────────────────────────────
# These must be set — the suite will fail immediately with a clear error if missing.

# PDS core URL
E2E_PDS_URL=https://pds.example.com

# Auth service URL
E2E_AUTH_URL=https://auth.example.com

# Demo app URL — the trusted demo client (listed in pds-core's
# PDS_OAUTH_TRUSTED_CLIENTS env var). All existing scenarios use this one
# by default.
E2E_DEMO_URL=https://demo.example.com

# URL of a second demo client that is NOT listed in PDS_OAUTH_TRUSTED_CLIENTS.
# Needed by any scenario that exercises the trusted-vs-untrusted distinction
# (negative trust tests, multi-client session reuse, etc.) — see
# e2e/README.md#two-demo-clients for the full picture. Optional: when unset,
# scenarios tagged @untrusted-client are automatically excluded by
# e2e/cucumber.mjs and the rest of the suite runs normally.
E2E_DEMO_UNTRUSTED_URL=https://demo-untrusted.example.com

# ── Mailpit ───────────────────────────────────────────────────────────────────
# Required for OTP email scenarios. Leave E2E_MAILPIT_PASS empty to skip them.

E2E_MAILPIT_URL=https://mailpit.example.com
E2E_MAILPIT_USER=admin
E2E_MAILPIT_PASS=

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'true' to run headless (no visible browser window). Default: false.
# E2E_HEADLESS=false

# Required only by scenarios tagged @otp-expiry. Must match the
# deployment's EPDS_INTERNAL_SECRET so the test runner can call the
# auth-service test hooks (e.g. POST /_internal/test/expire-otp). When
# unset, @otp-expiry scenarios mark themselves pending and skip cleanly.
# E2E_INTERNAL_SECRET=

# HYPER-268 session-reuse scenarios are tagged @session-reuse and
# excluded by the default cucumber tag filter (see e2e/cucumber.mjs).
# They require pds-core and auth-service to share a parent domain
# (AUTH_HOSTNAME must end with .<PDS_HOSTNAME>), which Railway
# preview environments cannot satisfy because their services get
# unrelated random hostnames under the up.railway.app public suffix.
# To run them locally against a docker-compose stack where both
# services share a parent, override the tag filter:
#
#   pnpm --dir e2e exec cucumber-js --tags "@session-reuse"
